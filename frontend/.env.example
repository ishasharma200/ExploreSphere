# Image Storage Configuration
# Copy this file to .env.local and fill in your credentials
# DO NOT commit .env.local to git!

VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# --- CLOUDINARY (Recommended) ---
# Get these from: https://cloudinary.com/console
# 1. Cloud Name: Dashboard → Account Details
# 2. Upload Preset: Settings → Upload → Create "explore_sphere" unsigned preset
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=explore_sphere

# --- FIREBASE (Alternative) ---
# Get these from: https://console.firebase.google.com → Project Settings → Your apps
# Optional: Only needed if using Firebase instead of Cloudinary
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_bucket_name
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
