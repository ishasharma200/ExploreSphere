{
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^13.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "npm --prefix backend run lint -- --fix",
      "npm --prefix frontend run lint -- --fix"
    ],
    "*.{json,md}": [
      "npm --prefix backend run format",
      "npm --prefix frontend run format"
    ]
  }
}
