{
  "name": "explore-sphere-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd ../frontend && npm install && npm run build",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "postinstall": "cd ../frontend && npm install && npm run build",
    "test": "node --test",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2",
    "proxyquire": "^2.1.3"
  }
}
